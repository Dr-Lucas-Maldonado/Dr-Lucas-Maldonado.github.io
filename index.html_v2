<!-- SPECIALIZATIONS -->
<section id="specializations">
  <div class="section-header reveal">
    <span class="section-label">04</span>
    <h2 class="section-title">Specializations</h2>
    <span class="section-line"></span>
  </div>

  <div class="spec-grid">
    <div class="spec-card reveal">
      <div class="spec-icon">🔬</div>
      <div class="spec-title">Single-Cell & Transcriptomics</div>
      <div class="spec-desc">Bulk and single-cell RNA-seq, biomarker discovery, trajectory analysis, and spatial transcriptomics. Cell-type resolution analysis, epigenomics, and advanced integration with the scverse ecosystem.</div>
    </div>

    <div class="spec-card reveal">
      <div class="spec-icon">🏥</div>
      <div class="spec-title">Precision Medicine & Oncology</div>
      <div class="spec-desc">Variant discovery and clinical bioinformatics for hereditary diseases and cancer genomics. Survival analysis, risk stratification, and clinical pipeline development with regulatory alignment.</div>
    </div>

    <div class="spec-card reveal">
      <div class="spec-icon">🦠</div>
      <div class="spec-title">Metagenomics & Microbiome</div>
      <div class="spec-desc">Taxonomic and functional profiling of microbiota and ecosystems. Comprehensive analysis from sequencing through interpretation for therapeutic and ecological applications.</div>
    </div>

    <div class="spec-card reveal">
      <div class="spec-icon">💊</div>
