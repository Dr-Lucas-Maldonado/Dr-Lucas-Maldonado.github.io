<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dr. Lucas L. Maldonado, PhD — Bioinformatics Scientist</title>
  <meta name="description" content="Senior Bioinformatics Scientist and Manager with 15+ years of experience in NGS, multi-omics, and genomics strategy." />
  <!-- Open Graph -->
  <meta property="og:title" content="Dr. Lucas L. Maldonado, PhD — Bioinformatics Scientist" />
  <meta property="og:description" content="Senior Bioinformatics Scientist. NGS, Multi-Omics, Data Platforms & Genomics Strategy." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://mainprofile.netlify.app/" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧬</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0f0d;
      --bg2: #0f1712;
      --bg3: #141f1a;
      --surface: #192219;
      --surface2: #1e2a1f;
      --border: #2a3d2c;
      --border2: #334d35;
      --accent: #4ade80;
      --accent2: #86efac;
      --accent-dim: rgba(74, 222, 128, 0.12);
      --accent-dim2: rgba(74, 222, 128, 0.06);
      --text: #e8f0e9;
      --text2: #a8bfaa;
      --text3: #6b8a6d;
      --text4: #4a6b4c;
      --mono: 'DM Mono', monospace;
      --serif: 'DM Serif Display', serif;
      --sans: 'Instrument Sans', sans-serif;
      --radius: 4px;
      --radius2: 8px;
      --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 15px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* NOISE TEXTURE OVERLAY */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.4;
    }

    /* SCROLLBAR */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

    /* NAV */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 0 2rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(10, 15, 13, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      transition: border-color var(--transition);
    }

    .nav-logo {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--accent);
      letter-spacing: 0.08em;
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--text3);
      text-decoration: none;
      text-transform: uppercase;
      transition: color var(--transition);
    }

    .nav-links a:hover { color: var(--accent); }

    .nav-cta {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 6px 16px;
      background: var(--accent-dim);
      border: 1px solid var(--border2);
      color: var(--accent) !important;
      border-radius: var(--radius);
      transition: all var(--transition) !important;
    }

    .nav-cta:hover {
      background: rgba(74, 222, 128, 0.2) !important;
      border-color: var(--accent) !important;
    }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 4rem;
      align-items: center;
      padding: 120px 4rem 80px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -200px;
      right: -100px;
      width: 700px;
      height: 700px;
      background: radial-gradient(circle, rgba(74, 222, 128, 0.06) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border2), transparent);
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 5px 12px;
      background: var(--accent-dim);
      border: 1px solid var(--border2);
      border-radius: 20px;
      margin-bottom: 1.5rem;
      animation: fadeUp 0.6s ease both;
    }

    .hero-badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse 2s ease infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }

    .hero-badge span {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--accent2);
      text-transform: uppercase;
    }

    .hero-title {
      font-family: var(--serif);
      font-size: clamp(2.8rem, 5vw, 4.2rem);
      line-height: 1.1;
      letter-spacing: -0.01em;
      color: var(--text);
      animation: fadeUp 0.6s ease 0.1s both;
    }

    .hero-title em {
      font-style: italic;
      color: var(--accent2);
    }

    .hero-subtitle {
      margin-top: 0.5rem;
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.06em;
      color: var(--text3);
      animation: fadeUp 0.6s ease 0.15s both;
    }

    .hero-description {
      margin-top: 1.5rem;
      font-size: 16px;
      line-height: 1.75;
      color: var(--text2);
      max-width: 580px;
      animation: fadeUp 0.6s ease 0.2s both;
    }

    .hero-stats {
      display: flex;
      gap: 2.5rem;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      animation: fadeUp 0.6s ease 0.25s both;
    }

    .stat-item {}
    .stat-number {
      font-family: var(--serif);
      font-size: 2.4rem;
      color: var(--accent);
      line-height: 1;
    }
    .stat-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      color: var(--text3);
      text-transform: uppercase;
      margin-top: 4px;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      margin-top: 2rem;
      animation: fadeUp 0.6s ease 0.3s both;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 22px;
      background: var(--accent);
      color: #0a0f0d;
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 500;
      border-radius: var(--radius);
      text-decoration: none;
      transition: all var(--transition);
    }

    .btn-primary:hover {
      background: var(--accent2);
      transform: translateY(-1px);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 22px;
      background: transparent;
      color: var(--text2);
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border: 1px solid var(--border2);
      border-radius: var(--radius);
      text-decoration: none;
      transition: all var(--transition);
    }

    .btn-secondary:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* HERO VISUAL PANEL */
    .hero-panel {
      animation: fadeUp 0.6s ease 0.35s both;
    }

    .hero-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius2);
      overflow: hidden;
    }

    .hero-card-header {
      padding: 14px 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-red { background: #ff5f57; }
    .dot-yellow { background: #febc2e; }
    .dot-green { background: #28c840; }

    .hero-card-label {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
      margin-left: auto;
    }

    .hero-card-body { padding: 20px; }

    .code-line {
      font-family: var(--mono);
      font-size: 12px;
      line-height: 2;
      color: var(--text3);
    }

    .code-line .k { color: #86efac; }
    .code-line .s { color: #fde68a; }
    .code-line .n { color: #93c5fd; }
    .code-line .c { color: #6b8a6d; }
    .code-line .v { color: #f9a8d4; }

    .contact-links {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .contact-link {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text2);
      text-decoration: none;
      padding: 6px 8px;
      border-radius: var(--radius);
      transition: all var(--transition);
    }

    .contact-link:hover {
      background: var(--accent-dim);
      color: var(--accent);
    }

    .contact-link-icon {
      width: 16px;
      opacity: 0.6;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* SECTION */
    section {
      padding: 80px 4rem;
      border-bottom: 1px solid var(--border);
    }

    .section-header {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .section-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.12em;
      color: var(--accent);
      text-transform: uppercase;
    }

    .section-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      color: var(--text);
      line-height: 1.15;
    }

    .section-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--border2), transparent);
    }

    /* ABOUT */
    .about-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 3rem;
      align-items: start;
    }

    .about-text p {
      color: var(--text2);
      line-height: 1.8;
      margin-bottom: 1.2rem;
      font-size: 15.5px;
    }

    .about-text p:last-child { margin-bottom: 0; }

    .about-aside {}

    .aside-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius2);
      padding: 20px;
      margin-bottom: 16px;
    }

    .aside-block-title {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--text3);
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .domain-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      background: var(--accent-dim2);
      border: 1px solid var(--border);
      border-radius: 20px;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text2);
      margin: 3px;
      transition: all var(--transition);
    }

    .domain-tag:hover {
      border-color: var(--border2);
      color: var(--accent2);
    }

    /* EXPERIENCE */
    .experience-list { display: flex; flex-direction: column; gap: 0; }

    .exp-item {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 0;
      position: relative;
    }

    .exp-item::before {
      content: '';
      position: absolute;
      left: 200px;
      top: 0;
      bottom: 0;
      width: 1px;
      background: var(--border);
    }

    .exp-meta {
      padding: 28px 28px 28px 0;
      position: sticky;
      top: 80px;
    }

    .exp-period {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
      letter-spacing: 0.06em;
    }

    .exp-org {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--accent2);
      margin-top: 4px;
      line-height: 1.4;
    }

    .exp-content {
      padding: 28px 0 28px 32px;
      border-top: 1px solid var(--border);
    }

    .exp-item:first-child .exp-content { border-top: none; }

    .exp-role {
      font-family: var(--serif);
      font-size: 1.3rem;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 12px;
    }

    .exp-bullets {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .exp-bullets li {
      display: flex;
      gap: 10px;
      color: var(--text2);
      font-size: 14.5px;
      line-height: 1.6;
    }

    .exp-bullets li::before {
      content: '→';
      color: var(--text4);
      font-family: var(--mono);
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* SKILLS */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .skill-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius2);
      padding: 24px;
      transition: all var(--transition);
      position: relative;
      overflow: hidden;
    }

    .skill-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), transparent);
      opacity: 0;
      transition: opacity var(--transition);
    }

    .skill-card:hover { border-color: var(--border2); transform: translateY(-2px); }
    .skill-card:hover::before { opacity: 1; }

    .skill-card-icon {
      font-size: 1.4rem;
      margin-bottom: 12px;
    }

    .skill-card-title {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: 12px;
    }

    .skill-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    .skill-tag {
      font-family: var(--mono);
      font-size: 10.5px;
      color: var(--text3);
      padding: 3px 8px;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 3px;
    }

    /* PUBLICATIONS */
    .pub-filters {
      display: flex;
      gap: 8px;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }

    .pub-filter {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 5px 12px;
      border: 1px solid var(--border);
      border-radius: 20px;
      background: transparent;
      color: var(--text3);
      cursor: pointer;
      transition: all var(--transition);
    }

    .pub-filter:hover, .pub-filter.active {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-dim);
    }

    .pub-list { display: flex; flex-direction: column; gap: 0; }

    .pub-item {
      padding: 20px 0;
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 40px 1fr auto;
      gap: 16px;
      align-items: start;
      transition: all var(--transition);
    }

    .pub-item:hover { background: var(--accent-dim2); padding-left: 8px; padding-right: 8px; margin: 0 -8px; border-radius: var(--radius); }

    .pub-num {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text4);
      padding-top: 2px;
    }

    .pub-title {
      font-size: 14.5px;
      color: var(--text);
      line-height: 1.5;
      font-weight: 500;
    }

    .pub-meta {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
      margin-top: 4px;
    }

    .pub-link {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      text-decoration: none;
      white-space: nowrap;
      padding: 3px 8px;
      border: 1px solid var(--border2);
      border-radius: var(--radius);
      transition: all var(--transition);
    }

    .pub-link:hover { background: var(--accent-dim); }

    .pub-more {
      text-align: center;
      padding: 24px 0 0;
    }

    /* SPECIALIZATIONS */
    .spec-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .spec-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius2);
      padding: 28px;
      transition: all var(--transition);
      cursor: default;
    }

    .spec-card:hover {
      border-color: var(--border2);
      background: var(--surface2);
    }

    .spec-icon {
      font-size: 1.8rem;
      margin-bottom: 14px;
    }

    .spec-title {
      font-family: var(--serif);
      font-size: 1.15rem;
      color: var(--text);
      margin-bottom: 8px;
    }

    .spec-desc {
      font-size: 13.5px;
      color: var(--text3);
      line-height: 1.6;
    }

    /* EDUCATION */
    .edu-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 2rem;
    }

    .edu-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius2);
      padding: 24px;
    }

    .edu-degree {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 8px;
    }

    .edu-title {
      font-size: 14px;
      color: var(--text);
      font-weight: 600;
      line-height: 1.4;
      margin-bottom: 6px;
    }

    .edu-institution {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
    }

    /* CONTACT */
    #contact {
      background: var(--bg2);
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    .contact-left {}
    .contact-tagline {
      font-family: var(--serif);
      font-size: 2rem;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 1rem;
    }

    .contact-tagline em { font-style: italic; color: var(--accent2); }

    .contact-desc {
      color: var(--text2);
      line-height: 1.75;
      margin-bottom: 2rem;
    }

    .contact-items {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }

    .contact-item-icon {
      width: 36px;
      height: 36px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
      transition: all var(--transition);
    }

    .contact-item:hover .contact-item-icon {
      border-color: var(--accent);
      background: var(--accent-dim);
    }

    .contact-item-text {}

    .contact-item-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      color: var(--text3);
      text-transform: uppercase;
    }

    .contact-item-value {
      font-size: 13px;
      color: var(--text2);
      transition: color var(--transition);
    }

    .contact-item:hover .contact-item-value { color: var(--accent2); }

    /* CONTACT FORM */
    .contact-form {}

    .form-group { margin-bottom: 16px; }

    .form-label {
      display: block;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      color: var(--text3);
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .form-input, .form-textarea {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 14px;
      color: var(--text);
      font-family: var(--sans);
      font-size: 14px;
      transition: all var(--transition);
      outline: none;
      resize: vertical;
    }

    .form-input:focus, .form-textarea:focus {
      border-color: var(--accent);
      background: var(--surface2);
    }

    .form-textarea { min-height: 120px; }

    .form-submit {
      width: 100%;
      padding: 12px;
      background: var(--accent);
      color: #0a0f0d;
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 500;
      border: none;
      border-radius: var(--radius);
      cursor: pointer;
      transition: all var(--transition);
    }

    .form-submit:hover { background: var(--accent2); }

    .form-success {
      display: none;
      padding: 16px;
      background: var(--accent-dim);
      border: 1px solid var(--border2);
      border-radius: var(--radius);
      font-family: var(--mono);
      font-size: 12px;
      color: var(--accent2);
      text-align: center;
    }

    /* FOOTER */
    footer {
      padding: 2rem 4rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid var(--border);
    }

    .footer-text {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text4);
    }

    .footer-links { display: flex; gap: 1.5rem; }

    .footer-link {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text3);
      text-decoration: none;
      transition: color var(--transition);
    }

    .footer-link:hover { color: var(--accent); }

    /* MOBILE NAV TOGGLE */
    .nav-toggle { display: none; background: none; border: none; cursor: pointer; }
    .nav-toggle-icon { width: 20px; height: 14px; display: flex; flex-direction: column; justify-content: space-between; }
    .nav-toggle-icon span { display: block; height: 1px; background: var(--text2); transition: all var(--transition); }

    /* UTILITY */
    .highlight { color: var(--accent2); }
    .mono { font-family: var(--mono); }

    /* SCROLL REVEAL */
    .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* RESPONSIVE */
    @media (max-width: 1100px) {
      .hero { grid-template-columns: 1fr; padding: 100px 2rem 60px; }
      .hero-panel { display: none; }
      .hero-stats { gap: 2rem; }
      .skills-grid { grid-template-columns: repeat(2, 1fr); }
      .about-grid { grid-template-columns: 1fr; }
      section { padding: 60px 2rem; }
    }

    @media (max-width: 768px) {
      nav { padding: 0 1.5rem; }
      .nav-links { display: none; }
      .nav-toggle { display: block; }
      .hero { padding: 90px 1.5rem 50px; }
      .exp-item { grid-template-columns: 1fr; }
      .exp-item::before { display: none; }
      .exp-meta { padding: 24px 0 0; }
      .exp-content { padding: 12px 0 24px; border-top: none; }
      .skills-grid { grid-template-columns: 1fr; }
      .spec-grid { grid-template-columns: 1fr; }
      .edu-grid { grid-template-columns: 1fr; }
      .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
      footer { flex-direction: column; gap: 1rem; text-align: center; }
      section { padding: 50px 1.5rem; }
    }
  </style>
</head>
